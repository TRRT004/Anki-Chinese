# ── Notion ────────────────────────────────────────────────────────────────────
# Found at https://www.notion.so/my-integrations → your integration → "Internal Integration Token"
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The 32-char ID in the Notion database URL:
# https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Upload backend ────────────────────────────────────────────────────────────
# Comma-separated — use one, both, or none:
#   none              → local file only, no upload
#   github            → GitHub Releases only
#   s3                → AWS S3 only
#   github,s3         → upload to both simultaneously
UPLOAD_BACKEND=github

# ── GitHub Releases backend ───────────────────────────────────────────────────
# Create a token at https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Format: owner/repo  (the repo where releases will be created)
GITHUB_REPO=your-username/anki-decks

# ── AWS S3 backend ────────────────────────────────────────────────────────────
# Only required when UPLOAD_BACKEND=s3
S3_BUCKET=your-bucket-name
S3_KEY_PREFIX=anki/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
