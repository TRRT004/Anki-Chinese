# ── Notion ────────────────────────────────────────────────────────────────────
# Found at https://www.notion.so/my-integrations → your integration → "Internal Integration Token"
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The 32-char ID in the Notion database URL:
# https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Upload backend ────────────────────────────────────────────────────────────
# Comma-separated — use one, both, or none:
#   none              → local .apkg only, no upload
#   github            → GitHub Releases (versioned download link)
#   ankiweb           → sync directly to AnkiWeb (fully headless, no local Anki needed)
#   github,ankiweb    → both simultaneously
UPLOAD_BACKEND=ankiweb

# ── GitHub Releases backend ───────────────────────────────────────────────────
# Create a token at https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Format: owner/repo
GITHUB_REPO=your-username/anki-decks

# ── AnkiWeb backend ───────────────────────────────────────────────────────────
# Your ankiweb.net login credentials.
# The container maintains a persistent collection (Docker volume) and syncs
# only the diff on each run — no Anki desktop or GUI required.
ANKIWEB_USERNAME=you@example.com
ANKIWEB_PASSWORD=your-ankiweb-password
# Path inside the container where the collection is stored (leave as default).
# ANKI_COLLECTION_PATH=/collection
